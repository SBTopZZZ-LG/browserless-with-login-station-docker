# ─────────────────────────────────────────────────────────────────────────────
# Environment Configuration
# Copy this file to .env and fill in your values.
# All values here are defaults — override as needed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Domain & SSL ─────────────────────────────────────────────────────────────
# Your top-level domain (e.g. example.com)
DOMAIN=saumitra1912.com

# Subdomains — set these to match your DNS A/CNAME records
#   browserless.YOUR_DOMAIN  → headless WS API (for Playwright/MCP)
#   login.YOUR_DOMAIN        → KasmVNC login UI
#   scrape.YOUR_DOMAIN       → authenticated scrape REST API
BROWSERLESS_DOMAIN=browserless.YOUR_DOMAIN
LOGIN_DOMAIN=login.YOUR_DOMAIN
SCRAPE_DOMAIN=scrape.YOUR_DOMAIN

# ── Browserless Token ─────────────────────────────────────────────────────────
# Secret token for browserless API authentication.
# Generate a strong random string, e.g.:
#   openssl rand -hex 32
BROWSERLESS_TOKEN=changeme_generate_with_openssl_rand_hex_32

# ── Login Station ─────────────────────────────────────────────────────────────
# Display settings for KasmVNC Chromium
DISPLAY_WIDTH=1920
DISPLAY_HEIGHT=1080
DISPLAY_REFRESH=60
DARK_MODE=true
LOGIN_STATION_TITLE=Browserless Login Station

# ── Browserless Limits ────────────────────────────────────────────────────────
BROWSERLESS_CONCURRENT=5
BROWSERLESS_MAX_SESSIONS=5
BROWSERLESS_QUEUED=10
BROWSERLESS_MAX_QUEUE=10
BROWSERLESS_TIMEOUT=600000
BROWSERLESS_MAX_MEMORY=80
BROWSERLESS_MAX_CPU=80

# ── System ────────────────────────────────────────────────────────────────────
# Your user's UID/GID (run: id $USER to find these)
PUID=1000
PGID=1000

# Timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=Asia/Kolkata