# ─────────────────────────────────────────────────────────────────────────────
# Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Mode ────────────────────────────────────────────────────────────────────
# Set to "true" to enable HTTPS via nginx reverse proxy.
# When false: direct HTTP on localhost (127.0.0.1), no nginx.
# When true: nginx handles TLS termination on ports 80/443.
USE_SSL=false

# ── Domain (used when USE_SSL=true) ─────────────────────────────────────────
# Your top-level domain — nginx routes subdomains to respective services.
DOMAIN=example.com

# Subdomains — create DNS A/CNAME records for each:
#   login.YOUR_DOMAIN      → KasmVNC web UI
#   scrape.YOUR_DOMAIN    → authenticated scrape REST API
#   browserless.YOUR_DOMAIN → headless Chrome WS API
LOGIN_DOMAIN=login.${DOMAIN}
SCRAPE_DOMAIN=scrape.${DOMAIN}
BROWSERLESS_DOMAIN=browserless.${DOMAIN}

# ── SSL Certificates (required when USE_SSL=true) ───────────────────────────
# Path to fullchain.pem and privkey.pem on the HOST (volume-mounted into nginx).
# Example: /etc/letsencrypt/live/login.${DOMAIN}/fullchain.pem
SSL_CERT_PATH=
SSL_KEY_PATH=

BUILD_DATE=${BUILD_DATE:-}
VCS_REF=${VCS_REF:-}

# ── Image ────────────────────────────────────────────────────────────────────
# For GHCR: set GITHUB_REPO to your GitHub handle (e.g. mygithubhandle).
# The image URL becomes: ghcr.io/<GITHUB_REPO>/browserless-login-station:<tag>
# See .github/workflows/build-push.yml to enable automatic GHCR pushes.
GITHUB_REPO=YOUR_GITHUB_HANDLE

# ── Browserless Token ─────────────────────────────────────────────────────────
# Strong secret for browserless API auth.
# Generate: openssl rand -hex 32
BROWSERLESS_TOKEN=

# ── Login Station ─────────────────────────────────────────────────────────────
LOGIN_STATION_TITLE=Browserless Login Station
DISPLAY_WIDTH=1920
DISPLAY_HEIGHT=1080
DISPLAY_REFRESH=60
DARK_MODE=true

# ── Browserless Limits ────────────────────────────────────────────────────────
BROWSERLESS_CONCURRENT=5
BROWSERLESS_MAX_SESSIONS=5
BROWSERLESS_QUEUED=10
BROWSERLESS_MAX_QUEUE=10
BROWSERLESS_TIMEOUT=600000
BROWSERLESS_MAX_MEMORY=80
BROWSERLESS_MAX_CPU=80

# ── Port Overrides (usually fine at defaults) ────────────────────────────────
# Host ports — change if you have conflicts.
# Local dev mode (USE_SSL=false): accessed directly at these ports.
# Production mode (USE_SSL=true): nginx routes 80/443, these are internal.
AUTH_PROXY_HOST_PORT=127.0.0.1:3100
CDP_HOST_PORT=127.0.0.1:9224
BROWSERLESS_HOST_PORT=127.0.0.1:3000
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Internal container ports (usually don't need changing)
KASMVNC_PORT=3100
AUTH_PROXY_PORT=3100
BROWSERLESS_PORT=3000

# ── System ───────────────────────────────────────────────────────────────────
PUID=1000
PGID=1000
TZ=UTC